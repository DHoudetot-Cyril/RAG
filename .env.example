# Environment Configuration - vLLM Edition

# Hugging Face Token (required for gated models)
HF_TOKEN=your-huggingface-token-here

# LLM Model - Options recommandées pour V100 32GB:
# - Qwen/Qwen2.5-7B-Instruct (recommandé - excellent FR/EN, rapide)
# - mistralai/Mistral-Nemo-Instruct-2407 (12B, très bon multilingue)
# - meta-llama/Meta-Llama-3.1-8B-Instruct (bon équilibre)
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# vLLM Server
VLLM_HOST=vllm
VLLM_PORT=8000

# Embedding
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Collection
COLLECTION_NAME=rag_ig2i

# API Security
API_KEY=your-secret-api-key-here
