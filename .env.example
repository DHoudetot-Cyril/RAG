# Environment Configuration - vLLM Edition

# Hugging Face Token (required for gated models)
HF_TOKEN=your-huggingface-token-here

# LLM Model - Qwen3 30B A3B AWQ 4-bit (optimisé V100 32GB)
# Autres options :
# - Qwen/Qwen2.5-7B-Instruct (plus rapide, moins intelligent)
# - mistralai/Mistral-Nemo-Instruct-2407 (12B, bon multilingue)
LLM_MODEL=cyankiwi/Qwen3-30B-A3B-Instruct-2507-AWQ-4bit

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# vLLM Server
VLLM_HOST=vllm
VLLM_PORT=8000

# Embedding
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Collection
COLLECTION_NAME=rag_ig2i

# API Security
API_KEY=your-secret-api-key-here
